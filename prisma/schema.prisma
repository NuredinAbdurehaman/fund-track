generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Transaction {
  id        String   @id @default(uuid())
  type      String
  amount    Decimal  @db.Decimal(12, 2)
  category  String
  date      DateTime @db.Date
  note      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("transactions")
}
